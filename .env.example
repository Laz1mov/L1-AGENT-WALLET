# 🗿 Sovereign Bitcoin Agent - Environment Configuration Example
# Copy this file to .env and fill in your real values.

# --- Sovereign Identity (Generated by sovereign_onboarding.py) ---
# 🔑 Enclave Secret Key — 32-byte hex. AUTO-GENERATED on first onboarding.
# ⚠️  BACKUP THIS KEY. If lost, the Agent's MAST address is unrecoverable.
# ENCLAVE_SECRET_KEY=""
# Your X-only public key (64 hex chars, no 02/03 prefix)
# MASTER_HUMAN_PUBKEY=""
# Your mainnet receive address (for minted Runes delivery)
# MASTER_RECEIVE_ADDRESS="bc1p..."
# Network: mainnet, testnet, signet
BITCOIN_NETWORK="mainnet"
MAINNET_API_URL="https://mempool.space/api"

# --- Mutinynet / Signet (Development) ---
MUTINYNET_API_URL="https://mutinynet.com/api"
MUTINYNET_EXPLORER_URL="https://mutinynet.com"

# --- Enclave Runtime Configuration ---
ENCLAVE_HOST="127.0.0.1"
ENCLAVE_PORT=7777
ENCLAVE_PSBT_GEN_PATH="./enclave-signer/target/release/gen_live_psbt"

# --- Logging & Security ---
# Log level for the Bridge (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL="INFO"
# Optional: Path to a custom log file (Defaults to stdout if not set)
# SOVEREIGN_LOG_PATH="./mcp_bridge.log"

# --- External Services ---
# Anthropic API Key (Primary Reasoning)
# ANTHROPIC_API_KEY="sk-ant-..."

# Ollama Global Config (Local Fallback)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_BIG_MODEL="hermes3"

# Telegram Integration (UI Hub)
# TELEGRAM_BOT_TOKEN="8302966980:AA..."
# TELEGRAM_CHAT_ID="723456789"
